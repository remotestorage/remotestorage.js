{
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "lib": ["es2020", "dom"],
    "types": ["node"],
    "sourceMap": true,
    "allowJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "build",
    "rootDir": "./src",
    "strict": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "ts-node": {
    "files": true
  }
}
